# FinShield AI — Backend Environment Variables
# Copy to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase (default for testing)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Local dev SQLite fallback (use instead of Supabase for offline dev)
# DATABASE_URL=sqlite+aiosqlite:///./finshield_dev.db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-string-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── Email providers (Resend primary, Brevo fallback — both optional) ─────────
# Resend.com — free tier 3K/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# Brevo (formerly Sendinblue) — free tier 300 emails/day; used when Resend is unset
BREVO_API_KEY=
EMAIL_FROM=noreply@finshield.ai
EMAIL_FROM_NAME=FinShield AI

# ── SMS (Twilio — optional) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Push Notifications (Firebase — optional) ──────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=./firebase-service-account.json

# ── ML ────────────────────────────────────────────────────────────────────────
ML_MODEL_PATH=app/ml/models
ML_FRAUD_MODEL_VERSION=latest

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=FinShield AI
APP_VERSION=1.0.0
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Encryption (for stored DB credentials) ───────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=your-32-byte-base64-encryption-key-here

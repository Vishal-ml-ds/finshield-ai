backend/app/ml/models/*.pytorch
backend/app/ml/models/*.pt

# Model artifacts and data
# NOTE: bare 'models/' removed — it was silently excluding backend/app/models/*.py
# ML binary artifacts are already covered by the specific glob patterns above.
data/
artifacts/


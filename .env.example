# ===========================================
# FinShield Fraud Detection Platform
# Environment Configuration
# ===========================================

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME=FinShield
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO



# ===========================================
# BACKEND API SETTINGS
# ===========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1

# ===========================================
# DATABASE SETTINGS (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql+asyncpg://finshield_user:finshield_password@localhost:5432/finshield_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=finshield_db
DATABASE_USER=finshield_user
DATABASE_PASSWORD=finshield_password

# Supabase (for production/testing)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===========================================
# REDIS SETTINGS (Cache & Queue)
# ===========================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===========================================
# JWT AUTHENTICATION
# ===========================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ===========================================
# AZURE SETTINGS (Production)
# ===========================================
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=finshieldstorage
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=finshieldstorage;AccountKey=your-key;EndpointSuffix=core.windows.net

# Azure Key Vault
AZURE_KEY_VAULT_NAME=finshield-kv
AZURE_KEY_VAULT_URL=https://finshield-kv.vault.azure.net/

# Azure Event Hubs
AZURE_EVENT_HUBS_CONNECTION_STRING=your-event-hubs-connection-string
AZURE_EVENT_HUBS_NAME=transactions

# ===========================================
# EMAIL SETTINGS
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
FROM_EMAIL=noreply@finshield.com
FROM_NAME=FinShield Security

# SendGrid (alternative)
SENDGRID_API_KEY=your-sendgrid-api-key

# ===========================================
# SMS SETTINGS (Twilio)
# ===========================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ===========================================
# FRONTEND SETTINGS
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Azure AD (for production)
AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret
AZURE_AD_TENANT_ID=your-azure-ad-tenant-id

# ===========================================
# ML MODEL SETTINGS
# ===========================================
ML_MODEL_PATH=./backend/app/ml/models
ML_FRAUD_MODEL_VERSION=latest
ML_BATCH_SIZE=32
ML_MAX_SEQUENCE_LENGTH=100

# Model training
ML_TRAINING_DATA_PATH=./data/training
ML_TEST_SIZE=0.2
ML_RANDOM_STATE=42

# ===========================================
# EXTERNAL API KEYS
# ===========================================
# For data connectors and integrations
STRIPE_API_KEY=sk_test_your-stripe-key
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Fraud prevention services
MAXMIND_ACCOUNT_ID=your-maxmind-account-id
MAXMIND_LICENSE_KEY=your-maxmind-license-key

# ===========================================
# SECURITY SETTINGS
# ===========================================
SECRET_KEY=your-django-style-secret-key
ENCRYPTION_KEY=your-32-byte-encryption-key
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60

# ===========================================
# MONITORING & LOGGING
# ===========================================
# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=your-app-insights-connection-string

# Sentry (error tracking)
SENTRY_DSN=your-sentry-dsn

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
# Database seeding
SEED_DATA=true
SEED_USERS_COUNT=10
SEED_TRANSACTIONS_COUNT=10000

# Test settings
TEST_DATABASE_URL=postgresql+asyncpg://test_user:test_password@localhost:5433/test_db

# ===========================================
# DOCKER SETTINGS
# ===========================================
COMPOSE_PROJECT_NAME=finshield
DOCKER_BUILDKIT=1

# ===========================================
# MULTI-TENANT SETTINGS
# ===========================================
MULTI_TENANT_ENABLED=true
DEFAULT_TENANT_ID=default
TENANT_SCHEMA_PREFIX=tenant_

# ===========================================
# FEATURE FLAGS
# ===========================================
FEATURE_ML_MODELS=true
FEATURE_RULES_ENGINE=true
FEATURE_REAL_TIME_DASHBOARD=true
FEATURE_CASE_MANAGEMENT=true
FEATURE_CONNECTORS=true
FEATURE_AUDIT_LOG=true